# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs（SOLA カウンセリングの読み上げ）
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Google Cloud TTS（SNS 等 — /api/counseling/speech では未使用）
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# Supabase（Phase 2で使用）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# LIFF（LINEミニアプリ）ID — 予約ページ用。サロン特定は URL の ?salon_id=<salons.id>（マルチテナント）
NEXT_PUBLIC_LIFF_ID=

# App base URL (for internal callbacks between routes — email → scrape)
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# ──────────────────────────────────────────────────────────
# HP連携 (Hot Pepper Beauty sync)
# ──────────────────────────────────────────────────────────

# 32-byte hex-encoded key for AES-256-GCM (run once):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HP_ENCRYPTION_KEY=

# Domain used to mint per-salon inbound email addresses:  sync-<salonId>@<domain>
HP_SYNC_EMAIL_DOMAIN=sola-ai.jp

# External scraper service (AWS Lambda / Browserbase / Fly.io / VPS)
HP_SCRAPER_ENDPOINT=
HP_SCRAPER_API_KEY=

# Resend inbound email webhook secret (set as X-Webhook-Secret on the Resend webhook)
RESEND_WEBHOOK_SECRET=

# Shared secret so the email webhook can trigger the scrape endpoint server-side
HP_INTERNAL_TRIGGER_SECRET=
