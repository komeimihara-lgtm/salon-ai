{
  "framework": "nextjs",
  "buildCommand": "VERCEL_FORCE_NO_BUILD_CACHE=1 npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/precounseling",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/expiry-reminder",
      "schedule": "0 0 * * *"
    }
  ]
}
